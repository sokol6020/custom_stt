# Скопируйте в release.env и укажите свой токен:
#   copy config\release.env.example config\release.env
#
# Токен: https://github.com/settings/tokens
# Classic PAT: scope "repo" (или "public_repo")
# Fine-grained PAT: Repository = custom_stt, Contents = Read and write

GITHUB_TOKEN=
GITHUB_REPO=sokol6020/custom_stt
