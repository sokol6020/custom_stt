<Window x:Class="customSTT.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История транскрипций"
        Height="600" Width="800"
        MinWidth="640" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimaryBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource AppFont}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="8">
            <ListBox x:Name="HistoryListBox"
                     Style="{StaticResource HistoryListBoxStyle}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource HistoryItemBorderStyle}" Margin="0,2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <WrapPanel Grid.Row="0" Margin="0,0,0,10">
                                    <TextBlock Text="{Binding Timestamp, StringFormat='dd.MM.yyyy HH:mm'}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="11"
                                               Margin="0,0,12,4"/>
                                    <TextBlock Text="{Binding Model}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Margin="0,0,8,4"/>
                                    <TextBlock Text="{Binding Language}"
                                               Foreground="{StaticResource RecordingActiveBrush}"
                                               FontSize="11"
                                               Margin="0,0,8,4"/>
                                    <TextBlock Text="{Binding DurationSeconds, StringFormat='{}{0:F1} с'}"
                                               Foreground="{StaticResource SuccessBrush}"
                                               FontSize="11"
                                               Margin="0,0,0,4"/>
                                </WrapPanel>

                                <TextBlock Grid.Row="1"
                                           Text="{Binding Text}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13"
                                           LineHeight="20"
                                           TextWrapping="Wrap"/>

                                <StackPanel Grid.Row="2"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,12,0,0">
                                    <Button Content="Копировать"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Tag="{Binding}"
                                            Click="OnCopyClick"
                                            Margin="0,0,6,0"/>
                                    <Button Content="Удалить"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Tag="{Binding}"
                                            Click="OnDeleteClick"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Очистить всё"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="OnClearAllClick"
                    Margin="0,0,8,0"/>
            <Button Content="Закрыть"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OnCloseClick"
                    MinWidth="100"/>
        </StackPanel>
    </Grid>
</Window>
