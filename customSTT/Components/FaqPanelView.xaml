<UserControl x:Class="customSTT.Components.FaqPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch"
             FontFamily="{StaticResource AppFont}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
        <StackPanel>
            <TextBlock Text="Часто задаваемые вопросы" Style="{StaticResource SectionTitleStyle}"/>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Как начать запись?" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" Margin="0,0,0,6"/>
                    <TextBlock Style="{StaticResource BodyTextStyle}">
                        <Run Text="Нажмите кнопку записи в шапке или используйте "/>
                        <Run Text="{Binding HotkeyDisplay, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                        <Run Text="."/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Как работает вставка текста?" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" Margin="0,0,0,6"/>
                    <TextBlock Text="После остановки записи распознанный текст автоматически вставляется в активное поле ввода."
                               Style="{StaticResource BodyTextStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Где хранится история?" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" Margin="0,0,0,6"/>
                    <TextBlock Text="История сохраняется в папке Data рядом с приложением."
                               Style="{StaticResource BodyTextStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Как изменить модель?" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" Margin="0,0,0,6"/>
                    <TextBlock Text="Откройте вкладку «Настройки» и выберите модель Whisper. При первом использовании она загрузится автоматически."
                               Style="{StaticResource BodyTextStyle}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
