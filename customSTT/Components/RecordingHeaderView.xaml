<UserControl x:Class="customSTT.Components.RecordingHeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch"
             FontFamily="{StaticResource AppFont}">
    <Border Style="{StaticResource CardBorderStyle}" Padding="20,16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Speech to Text"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding HotkeyHintText}"
                           FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,4,0,0"/>

                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="{Binding ProgressCaptionText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,6"/>
                    <ProgressBar Value="{Binding ProcessingProgress}"
                                 Minimum="0"
                                 Maximum="100"
                                 Height="10"
                                 Style="{StaticResource ProcessingProgressBarStyle}"/>
                    <TextBlock Text="{Binding ProcessingProgress, StringFormat='{}{0:F0}%'}"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Right"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Margin="0,12,0,0">
                    <Border Background="{StaticResource BgSecondaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,8"
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Оверлей"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding OverlayStatusText}"
                                       Foreground="{Binding OverlayStatusColor}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button Content="{Binding OverlayToggleText}"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding ToggleOverlayCommand}"
                            ToolTip="{Binding OverlayHotkey, StringFormat='Вкл/выкл оверлея ({0})'}"
                            MinWidth="72"
                            VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="1"
                    Style="{StaticResource RecordButtonStyle}"
                    Command="{Binding ToggleRecordingCommand}"
                    ToolTip="Старт / стоп записи"
                    VerticalAlignment="Center"
                    Margin="20,0,0,0"/>
        </Grid>
    </Border>
</UserControl>
