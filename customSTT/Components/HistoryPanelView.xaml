<UserControl x:Class="customSTT.Components.HistoryPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch"
             FontFamily="{StaticResource AppFont}">
    <Grid HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Последние транскрипции"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Border Background="#1A2030"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10,4"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding HistoryCountText}"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Border>
                <Button Content="Очистить"
                        Style="{StaticResource ActionButtonStyle}"
                        Command="{Binding ClearHistoryCommand}"
                        Margin="0,0,6,0"/>
                <Button Content="Подробнее"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding OpenHistoryCommand}"/>
            </StackPanel>
        </Grid>

        <ListBox Grid.Row="1"
                 Style="{StaticResource HistoryListBoxStyle}"
                 MaxHeight="280"
                 ItemsSource="{Binding History}"
                 SelectedItem="{Binding SelectedHistoryEntry}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource HistoryItemBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="{Binding Text}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding Timestamp, StringFormat='dd.MM.yyyy HH:mm:ss'}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"
                                       Margin="0,6,0,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
