<UserControl x:Class="customSTT.Components.SettingsPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:customSTT.Components"
             HorizontalAlignment="Stretch"
             FontFamily="{StaticResource AppFont}">
    <TabControl MinHeight="280">
        <TabItem Header="Распознавание" Style="{StaticResource TabStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,12,4,4">
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Модель" Style="{StaticResource LabelStyle}" Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding AvailableModels}"
                                  SelectedIndex="{Binding SelectedModelIndex}"
                                  Style="{StaticResource ComboBoxStyle}"
                                  Margin="0,0,0,14">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="Язык" Style="{StaticResource LabelStyle}" Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                  SelectedIndex="{Binding SelectedLanguageIndex}"
                                  Style="{StaticResource ComboBoxStyle}"
                                  Margin="0,0,0,14">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="Микрофон" Style="{StaticResource LabelStyle}" Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding AudioDevices}"
                                  SelectedItem="{Binding SelectedAudioDevice}"
                                  Style="{StaticResource ComboBoxStyle}"
                                  Margin="0,0,0,14">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <CheckBox Content="GPU-ускорение распознавания"
                                  IsChecked="{Binding UseGpu}"
                                  Style="{StaticResource CheckBoxStyle}"
                                  ToolTip="NVIDIA: CUDA. AMD/Intel: Vulkan. При недоступности GPU используется CPU."/>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Запись" Style="{StaticResource TabStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,12,4,4">
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Горячая клавиша"
                                       Style="{StaticResource LabelStyle}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <Border Grid.Column="1"
                                    Style="{StaticResource HotkeyBadgeStyle}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,10,0">
                                <TextBlock Text="{Binding HotkeyDisplay}"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           HorizontalAlignment="Center"/>
                            </Border>
                            <Button Grid.Column="2"
                                    Content="Изменить"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding ChangeHotkeyCommand}"/>
                        </Grid>

                        <TextBlock Text="Режим записи"
                                   Style="{StaticResource LabelStyle}"
                                   Margin="0,14,0,6"/>
                        <ComboBox ItemsSource="{Binding AvailableHotkeyModes}"
                                  SelectedIndex="{Binding HotkeyModeIndex}"
                                  Style="{StaticResource ComboBoxStyle}"
                                  Margin="0,0,0,4">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <CheckBox Content="Распознавание по паузам"
                                      IsChecked="{Binding DictationOnPause}"
                                      Style="{StaticResource CheckBoxStyle}"
                                      Margin="0"
                                      VerticalAlignment="Center"/>
                            <Button Style="{StaticResource InfoHintButtonStyle}">
                                <Button.ToolTip>
                                    <ToolTip Style="{StaticResource InfoToolTipStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource InfoToolTipTextStyle}"
                                                       Text="Во время записи каждая фраза распознаётся и вставляется после короткой паузы. По умолчанию выключено: запись от нажатия до повторного нажатия или удержания клавиши."/>
                                            <TextBlock Style="{StaticResource InfoToolTipWarningStyle}"
                                                       Text="Нельзя использовать вместе с AI-редактором: фразы вставляются сразу, без пост-обработки."/>
                                        </StackPanel>
                                    </ToolTip>
                                </Button.ToolTip>
                            </Button>
                        </StackPanel>

                        <Border Background="{StaticResource BgSecondaryBrush}"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16"
                                Margin="0,14,0,0"
                                Visibility="{Binding IsCapturingHotkey, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Нажмите клавишу или комбинацию..."
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding HotkeyInputText}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,12"/>
                                <Button Content="Отмена"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding StopCaptureHotkeyCommand}"
                                        HorizontalAlignment="Center"
                                        MinWidth="100"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Оверлей" Style="{StaticResource TabStyle}">
            <components:OverlaySettingsPanelView/>
        </TabItem>

        <TabItem Header="Поведение" Style="{StaticResource TabStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,12,4,4">
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <CheckBox Content="Автозапуск при старте Windows"
                                  IsChecked="{Binding AutoStart}"
                                  Style="{StaticResource CheckBoxStyle}"/>
                        <CheckBox Content="Минимизация в трей при закрытии"
                                  IsChecked="{Binding MinimizedToTray}"
                                  Style="{StaticResource CheckBoxStyle}"/>
                        <CheckBox Content="Скрывать в трей при запуске"
                                  IsChecked="{Binding MinimizeToTrayOnStartup}"
                                  Style="{StaticResource CheckBoxStyle}"
                                  ToolTip="Окно не показывается при старте. Также работает параметр --minimize-to-tray."/>
                        <CheckBox Content="Проверять обновления при запуске"
                                  IsChecked="{Binding CheckUpdatesOnStartup}"
                                  Style="{StaticResource CheckBoxStyle}"/>

                        <Border Background="{StaticResource BgSecondaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14,12"
                                Margin="0,14,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding AppVersionText}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="13"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding UpdateStatusText}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12"
                                               Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Проверить обновления"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding CheckForUpdatesCommand}"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</UserControl>
